<section class="section-padding" style="background: color-mix(in oklab, var(--soft) 40%, transparent);">
  <div class="container-calm">
    <div style="display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 3rem;">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 style="font-size: clamp(1.75rem, 5vw, 3.25rem); margin-top: 0.5rem;">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ section.settings.collection | default: '/collections/all' | append: '' }}"
           class="arrow-link" style="color: var(--cta);">
          {{ section.settings.view_all_label }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- assign featured_collection = collections[section.settings.collection] -%}
    {%- if featured_collection != blank -%}
      {%- assign products_to_show = featured_collection.products | limit: section.settings.products_to_show -%}
    {%- else -%}
      {%- assign products_to_show = collections.all.products | limit: section.settings.products_to_show -%}
    {%- endif -%}

    <div class="ln-featured-products__grid">
      {%- for product in products_to_show -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p style="color: var(--muted-foreground);">Ingen produkter fundet.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .ln-featured-products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem 2rem;
  }
</style>

{% schema %}
{
  "name": "Udvalgte produkter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Udvalgt lige nu" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Et godt sted at starte" },
    { "type": "collection", "id": "collection", "label": "Kollektion" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 8, "step": 1, "label": "Antal produkter", "default": 4 },
    { "type": "text", "id": "view_all_label", "label": "\"Se alle\"-link tekst", "default": "Se alle produkter" }
  ],
  "presets": [{ "name": "Udvalgte produkter" }]
}
{% endschema %}
