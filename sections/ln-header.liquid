        { "type": "text", "id": "label", "label": "Tekst" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Header",
    "blocks": [
      { "type": "nav_item", "settings": { "label": "Køkken", "url": "/collections/all" } },
