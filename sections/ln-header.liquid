      { "type": "nav_item", "settings": { "label": "Slibning", "url": "/collections/slibning-pleje" } },
      { "type": "nav_item", "settings": { "label": "Magnetisk opbevaring", "url": "/collections/magnetiske-holdere" } },
      { "type": "nav_item", "settings": { "label": "Keramik", "url": "/pages/keramik" } },
      { "type": "nav_item", "settings": { "label": "Gaver", "url": "/collections/gaver" } },
