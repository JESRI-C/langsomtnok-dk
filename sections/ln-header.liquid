  <div class="container-calm">
    <div class="ln-trust-strip__row">
      <span class="ln-trust-strip__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Sendes fra Danmark · 1-2 dage
      </span>
      <span class="ln-trust-strip__dot" aria-hidden="true">·</span>
      <span class="ln-trust-strip__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        Fri fragt over 599 kr
      </span>
      <span class="ln-trust-strip__dot" aria-hidden="true">·</span>
      <span class="ln-trust-strip__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
        30 dages returret
      </span>
      <span class="ln-trust-strip__dot" aria-hidden="true">·</span>
      <span class="ln-trust-strip__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Sikker betaling
      </span>
    </div>
  </div>
</div>

<header class="ln-header" id="ln-header">
  <div class="container-calm">
    <div class="ln-header__inner">

      {%- comment -%} Logo {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="ln-header__logo" aria-label="{{ shop.name }} — forside">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 240 | image_tag: loading: 'eager', class: 'ln-header__logo-img', alt: shop.name }}
        {%- else -%}
          <span class="ln-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} Desktop nav {%- endcomment -%}
      <nav class="ln-header__nav" aria-label="Primær navigation">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_item' -%}
            <a href="{{ block.settings.url }}" class="ln-header__nav-link">{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      {%- comment -%} Right icons {%- endcomment -%}
      <div class="ln-header__actions">
        <a href="{{ routes.search_url }}" class="ln-header__icon-btn" aria-label="Søg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </a>
        <a href="{{ routes.cart_url }}" class="ln-header__icon-btn ln-header__cart-btn" aria-label="Indkøbskurv">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="ln-header__cart-badge">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
        <button class="ln-header__icon-btn ln-header__burger" id="ln-burger" aria-label="Åbn menu" aria-expanded="false" aria-controls="ln-mobile-nav">
          <svg class="ln-burger__open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="ln-burger__close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

    </div>
  </div>

  {%- comment -%} Mobile nav panel {%- endcomment -%}
  <div class="ln-mobile-nav" id="ln-mobile-nav" aria-hidden="true">
    <nav class="container-calm ln-mobile-nav__links">
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_item' -%}
          <a href="{{ block.settings.url }}" class="ln-mobile-nav__link">{{ block.settings.label }}</a>
        {%- endif -%}
      {%- endfor -%}
      <div class="ln-mobile-nav__trust">
        <div class="ln-mobile-nav__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Sendes fra Danmark · 1-2 dage
        </div>
        <div class="ln-mobile-nav__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          Fri fragt over 599 kr
        </div>
        <div class="ln-mobile-nav__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
          30 dages returret
        </div>
        <div class="ln-mobile-nav__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Sikker betaling
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Trust strip */
  .ln-trust-strip {
    background: color-mix(in oklab, var(--soft) 60%, var(--background));
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 8%, transparent);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: color-mix(in oklab, var(--foreground) 50%, transparent);
    overflow: hidden;
  }
  .ln-trust-strip__row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.5rem 0;
    white-space: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ln-trust-strip__row::-webkit-scrollbar { display: none; }
  .ln-trust-strip__item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }
  .ln-trust-strip__item svg { opacity: 0.45; flex-shrink: 0; }
  .ln-trust-strip__dot { opacity: 0.3; flex-shrink: 0; }

  /* Header */
  .ln-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--background);
    border-bottom: 1px solid color-mix(in oklab, var(--soft) 80%, transparent);
    transition: box-shadow 0.3s ease;
  }
  .ln-header.is-scrolled { box-shadow: 0 1px 12px color-mix(in oklab, var(--foreground) 8%, transparent); }
  .ln-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  @media (min-width: 768px) { .ln-header__inner { height: 72px; } }

  /* Logo */
  .ln-header__logo { flex-shrink: 0; display: flex; align-items: center; }
  .ln-header__logo-img { height: 40px; width: auto; }
  @media (min-width: 768px) { .ln-header__logo-img { height: 48px; } }
  .ln-header__logo-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.25rem;
    color: var(--foreground);
  }

  /* Desktop nav */
  .ln-header__nav {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }
  @media (min-width: 1200px) { .ln-header__nav { display: flex; } }
  .ln-header__nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: color-mix(in oklab, var(--foreground) 65%, transparent);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .ln-header__nav-link:hover { color: var(--cta); }

  /* Actions */
  .ln-header__actions { display: flex; align-items: center; gap: 0.25rem; }
  .ln-header__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem;
    color: color-mix(in oklab, var(--foreground) 50%, transparent);
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    border-radius: 0.25rem;
  }
  .ln-header__icon-btn:hover { color: var(--foreground); }
  .ln-header__cart-badge {
    position: absolute;
    top: 0;
    right: 0;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--cta);
    color: var(--cta-foreground);
    font-size: 0.5625rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .ln-header__burger { display: flex; }
  @media (min-width: 1200px) { .ln-header__burger { display: none; } }

  /* Mobile nav */
  .ln-mobile-nav {
    position: fixed;
    inset-x: 0;
    top: var(--header-height, 96px);
    bottom: 0;
    background: color-mix(in oklab, var(--background) 98%, transparent);
    backdrop-filter: blur(8px);
    z-index: 90;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }
  .ln-mobile-nav.is-open { transform: translateX(0); }
  .ln-mobile-nav__links {
    padding-top: 2rem;
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
  }
  .ln-mobile-nav__link {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.125rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 8%, transparent);
    transition: color 0.2s ease;
  }
  .ln-mobile-nav__link:hover { color: var(--foreground); }
  .ln-mobile-nav__trust {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in oklab, var(--foreground) 10%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ln-mobile-nav__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--foreground) 55%, transparent);
  }
  .ln-mobile-nav__trust-item svg { opacity: 0.6; flex-shrink: 0; }
</style>

<script>
  (function () {
    var header = document.getElementById('ln-header');
    var burger = document.getElementById('ln-burger');
    var nav = document.getElementById('ln-mobile-nav');
    var openIcon = burger && burger.querySelector('.ln-burger__open');
    var closeIcon = burger && burger.querySelector('.ln-burger__close');
    var isOpen = false;

    // Scroll shadow
    window.addEventListener('scroll', function () {
      header && header.classList.toggle('is-scrolled', window.scrollY > 10);
    }, { passive: true });

    // Set header height CSS var for mobile nav offset
    function setHeight() {
      if (header) document.documentElement.style.setProperty('--header-height', header.getBoundingClientRect().bottom + 'px');
    }
    setHeight();
    window.addEventListener('resize', setHeight);

    // Mobile toggle
    if (burger && nav) {
      burger.addEventListener('click', function () {
        isOpen = !isOpen;
        nav.classList.toggle('is-open', isOpen);
        burger.setAttribute('aria-expanded', isOpen);
        document.body.style.overflow = isOpen ? 'hidden' : '';
        if (openIcon) openIcon.style.display = isOpen ? 'none' : '';
        if (closeIcon) closeIcon.style.display = isOpen ? '' : 'none';
      });
    }
  })();
</script>

