<section class="section-padding">
  <div class="container-calm">
    <div style="display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 3rem;">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 style="font-size: clamp(1.75rem, 5vw, 3.25rem); margin-top: 0.5rem;">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.subheading != blank -%}
        <p style="color: var(--muted-foreground); max-width: 22rem; line-height: 1.6;">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="ln-categories__grid">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <a href="{{ collection.url | default: block.settings.url | default: '/collections/all' }}"
           class="ln-category-card lift-on-hover"
           {{ block.shopify_attributes }}>
          <div class="ln-category-card__image-wrap">
            <div class="ln-category-card__image-inner">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'ln-category-card__img' }}
              {%- elsif collection != blank and collection.featured_image -%}
                {{ collection.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'ln-category-card__img' }}
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--soft);"></div>
              {%- endif -%}
            </div>
          </div>
          <h3 class="ln-category-card__title">{{ block.settings.title }}</h3>
          <p class="ln-category-card__text">{{ block.settings.text }}</p>
          <span class="ln-category-card__cta arrow-link" style="color: var(--cta);">
            Se kollektionen
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .ln-categories__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem 1.5rem;
  }
  .ln-category-card {
    display: block;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--border) 70%, transparent);
    background: var(--card);
    padding: 0.75rem;
  }
  .ln-category-card__image-wrap {
    overflow: hidden;
    border-radius: 0.5rem;
    background: var(--soft);
    margin-bottom: 1.25rem;
    aspect-ratio: 4/5;
  }
  .ln-category-card__image-inner {
    width: 100%; height: 100%;
    transition: transform 700ms ease-out;
  }
  .ln-category-card:hover .ln-category-card__image-inner { transform: scale(1.03); }
  .ln-category-card__img { width: 100%; height: 100%; object-fit: cover; }
  .ln-category-card__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.25rem;
    margin-bottom: 0.375rem;
    padding: 0 0.25rem;
    transition: color 200ms;
  }
  .ln-category-card:hover .ln-category-card__title { color: var(--walnut); }
  .ln-category-card__text {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    margin-bottom: 0.75rem;
    padding: 0 0.25rem;
    line-height: 1.6;
  }
  .ln-category-card__cta { padding: 0 0.25rem; font-weight: 600; font-size: 0.875rem; }
</style>

{% schema %}
{
  "name": "Kategorigrid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Kategorier" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Find det, du leder efter" },
    { "type": "text", "id": "subheading", "label": "Underoverskrift", "default": "Fire indgange til et roligere køkken. Vælg dér, hvor du gerne vil starte." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategori",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Kollektion" },
        { "type": "url", "id": "url", "label": "Manuel URL (bruges hvis ingen kollektion)" },
        { "type": "image_picker", "id": "image", "label": "Billede (overstyrer kollektion-billede)" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "text", "id": "text", "label": "Beskrivelse" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Kategorigrid",
    "blocks": [
      { "type": "category", "settings": { "title": "Knive", "text": "Til dig, der vil lave mad med bedre grej." } },
      { "type": "category", "settings": { "title": "Slibning & pleje", "text": "Gør dine knive skarpe igen — i ro og mag." } },
      { "type": "category", "settings": { "title": "Magnetisk opbevaring", "text": "Få knivene væk fra skuffen. Sættes op uden boremaskine." } },
      { "type": "category", "settings": { "title": "Gaver", "text": "Gaver, der føles udvalgt — ikke tilfældige." } }
    ]
  }]
}
{% endschema %}
