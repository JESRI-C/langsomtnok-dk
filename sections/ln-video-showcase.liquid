<section class="section-padding" style="background: {% if section.settings.background == 'soft' %}color-mix(in oklab, var(--soft) 50%, var(--background)){% else %}var(--background){% endif %};">
  <div class="container-calm">
    <div class="ln-video-showcase__grid {% if section.settings.video_side == 'left' %}ln-video-showcase__grid--left{% endif %}">

      <div class="ln-video-showcase__text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 style="font-size: clamp(1.75rem, 4vw, 2.75rem); margin-top: 0.5rem; margin-bottom: 1.25rem; line-height: 1.1;">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}
          <p style="color: var(--muted-foreground); line-height: 1.75; max-width: 34rem; margin-bottom: 2rem;">{{ section.settings.body }}</p>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url }}" class="btn-cta">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>

      <div class="ln-video-showcase__media">
        {%- if section.settings.video_url != blank -%}
          <video autoplay muted loop playsinline
            style="width:100%;height:100%;object-fit:cover;border-radius:0.75rem;"
            {%- if section.settings.poster != blank -%}
              poster="{{ section.settings.poster | image_url: width: 900 }}"
            {%- endif -%}>
            <source src="{{ section.settings.video_url }}" type="video/mp4">
          </video>
        {%- elsif section.settings.poster != blank -%}
          {{ section.settings.poster | image_url: width: 900 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;border-radius:0.75rem;' }}
        {%- else -%}
          <div style="width:100%;height:100%;min-height:400px;background:var(--soft);border-radius:0.75rem;"></div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  .ln-video-showcase__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .ln-video-showcase__media {
    overflow: hidden;
    border-radius: 0.75rem;
    aspect-ratio: 16/10;
    order: -1;
  }
  @media (min-width: 768px) {
    .ln-video-showcase__grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
    .ln-video-showcase__media { order: 1; }
    .ln-video-showcase__grid--left .ln-video-showcase__media { order: -1; }
    .ln-video-showcase__grid--left .ln-video-showcase__text { order: 1; }
  }
</style>

{% schema %}
{
  "name": "Video showcase",
  "settings": [
    { "type": "select", "id": "background", "label": "Baggrund", "options": [
      { "value": "white", "label": "Hvid" },
      { "value": "soft", "label": "Varm" }
    ], "default": "soft" },
    { "type": "select", "id": "video_side", "label": "Video side", "options": [
      { "value": "right", "label": "Højre" },
      { "value": "left", "label": "Venstre" }
    ], "default": "right" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Overskrift" },
    { "type": "textarea", "id": "body", "label": "Brødtekst" },
    { "type": "text", "id": "cta_label", "label": "Knaptekst" },
    { "type": "url", "id": "cta_url", "label": "Knap-URL" },
    { "type": "text", "id": "video_url", "label": "Video URL (mp4)" },
    { "type": "image_picker", "id": "poster", "label": "Poster-billede" }
  ],
  "presets": [{
    "name": "Video showcase",
    "settings": {
      "eyebrow": "Et roligere køkken",
      "heading": "En lille opgradering. Mere ro i køkkenet.",
      "body": "Se hvor enkelt den magnetiske knivholder finder sin plads. Uden boremaskine. Uden støv.",
      "cta_label": "Se knivholderen",
      "background": "soft",
      "video_side": "right"
    }
  }]
}
{% endschema %}
