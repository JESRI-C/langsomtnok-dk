<section class="section-padding" style="background: var(--deep); color: var(--deep-foreground);">
  <div class="container-calm">
    <div style="max-width: 40rem; margin-bottom: 3.5rem;">
      <span style="display: block; font-size: 0.6875rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--copper); margin-bottom: 0.5rem;">{{ section.settings.eyebrow }}</span>
      <h2 style="font-size: clamp(1.75rem, 5vw, 3.25rem); line-height: 1.1;">{{ section.settings.heading }}</h2>
    </div>

    <div class="ln-materials__grid">
      {%- for block in section.blocks -%}
        <article class="ln-material-card" {{ block.shopify_attributes }}>
          <div class="ln-material-card__image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                alt: block.settings.name,
                class: 'ln-material-card__img'
              }}
            {%- endif -%}
          </div>
          <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.5rem; margin-bottom: 0.5rem;">{{ block.settings.name }}</h3>
          <p style="font-size: 0.875rem; color: var(--deep-foreground); opacity: 0.65; line-height: 1.6; max-width: 18rem;">{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .ln-materials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem 2.5rem;
  }
  .ln-material-card__image-wrap {
    overflow: hidden;
    border-radius: 0.5rem;
    aspect-ratio: 4/5;
    margin-bottom: 1.5rem;
  }
  .ln-material-card__img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1200ms ease-out;
  }
  .ln-material-card:hover .ln-material-card__img { transform: scale(1.04); }
</style>

{% schema %}
{
  "name": "Materialer",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Materialer" },
    { "type": "textarea", "id": "heading", "label": "Overskrift", "default": "Materialer, der bliver smukkere med brug." }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Materiale",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Billede" },
        { "type": "text", "id": "name", "label": "Navn" },
        { "type": "text", "id": "text", "label": "Beskrivelse" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{
    "name": "Materialer",
    "blocks": [
      { "type": "material", "settings": { "name": "Stål", "text": "Lagdelt. Skarpt. Skabt til præcision." } },
      { "type": "material", "settings": { "name": "Træ", "text": "Varmt, levende og forskelligt fra håndtag til håndtag." } },
      { "type": "material", "settings": { "name": "Sten", "text": "Skarphed kræver tålmodighed." } }
    ]
  }]
}
{% endschema %}
