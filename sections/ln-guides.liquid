<section class="section-padding">
  <div class="container-calm">
    <div style="display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 3rem;">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 style="font-size: clamp(1.75rem, 5vw, 3.25rem); margin-top: 0.5rem;">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ blogs[section.settings.blog].url | default: '/blogs/guides' }}" class="arrow-link" style="color: var(--cta);">
          {{ section.settings.view_all_label }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- assign blog_handle = section.settings.blog | default: 'guides' -%}
    {%- assign guides_blog = blogs[blog_handle] -%}

    <div class="ln-guides__grid">
      {%- if guides_blog != blank -%}
        {%- for article in guides_blog.articles limit: section.settings.articles_to_show -%}
          <a href="{{ article.url }}" class="ln-guide-card">
            <div class="ln-guide-card__image-wrap">
              {%- if article.image -%}
                <div class="ln-guide-card__image-inner">
                  {{ article.image | image_url: width: 600 | image_tag:
                    loading: 'lazy',
                    alt: article.image.alt | default: article.title,
                    class: 'ln-guide-card__img'
                  }}
                </div>
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--soft);"></div>
              {%- endif -%}
            </div>
            <h3 class="ln-guide-card__title">{{ article.title }}</h3>
            <p style="font-size: 0.875rem; color: var(--muted-foreground); line-height: 1.6; margin-bottom: 0.75rem;">
              {{ article.excerpt_or_content | strip_html | truncate: 100 }}
            </p>
            <span class="arrow-link" style="color: var(--cta); font-size: 0.875rem; font-weight: 500;">
              Læs guiden
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        {%- else -%}
          {%- comment -%} Fallback: hardcoded blocks if no blog exists yet {%- endcomment -%}
          {%- for block in section.blocks -%}
            <a href="{{ block.settings.url | default: '#' }}" class="ln-guide-card" {{ block.shopify_attributes }}>
              <div class="ln-guide-card__image-wrap">
                {%- if block.settings.image != blank -%}
                  <div class="ln-guide-card__image-inner">
                    {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'ln-guide-card__img' }}
                  </div>
                {%- else -%}
                  <div style="width:100%;height:100%;background:var(--soft);"></div>
                {%- endif -%}
              </div>
              <h3 class="ln-guide-card__title">{{ block.settings.title }}</h3>
              <p style="font-size: 0.875rem; color: var(--muted-foreground); line-height: 1.6; margin-bottom: 0.75rem;">{{ block.settings.excerpt }}</p>
              <span class="arrow-link" style="color: var(--cta); font-size: 0.875rem; font-weight: 500;">
                Læs guiden
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .ln-guides__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem 2rem;
  }
  .ln-guide-card { display: block; }
  .ln-guide-card__image-wrap {
    overflow: hidden; border-radius: 0.5rem;
    aspect-ratio: 4/3; background: var(--soft);
    margin-bottom: 1.25rem;
  }
  .ln-guide-card__image-inner {
    width: 100%; height: 100%;
    transition: transform 700ms ease-out;
  }
  .ln-guide-card:hover .ln-guide-card__image-inner { transform: scale(1.03); }
  .ln-guide-card__img { width: 100%; height: 100%; object-fit: cover; }
  .ln-guide-card__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.25rem; line-height: 1.3;
    margin-bottom: 0.5rem; transition: color 200ms;
  }
  .ln-guide-card:hover .ln-guide-card__title { color: var(--walnut); }
</style>

{% schema %}
{
  "name": "Guides-preview",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Læs" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Fra guiden" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "articles_to_show", "min": 2, "max": 6, "step": 1, "label": "Antal artikler", "default": 3 },
    { "type": "text", "id": "view_all_label", "label": "\"Se alle\"-link", "default": "Alle guides" }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Manuel artikel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Billede" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "text", "id": "excerpt", "label": "Uddrag" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "Guides-preview" }]
}
{% endschema %}
