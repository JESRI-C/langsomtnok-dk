<footer class="ln-footer">
  <div class="container-calm section-padding">

    {%- comment -%} Main grid {%- endcomment -%}
    <div class="ln-footer__grid">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="ln-footer__brand">
        <h2 class="ln-footer__brand-name">{{ shop.name }}</h2>
        <p class="ln-footer__brand-desc">
          {{ section.settings.brand_description | default: 'Køkkenredskaber og keramik skabt til dem, der ikke skynder sig gennem det vigtige. Træ, stål, olie, tid.' }}
        </p>
        <p class="ln-footer__brand-contact">
          Spørgsmål til et produkt? Skriv til
          <a href="mailto:{{ section.settings.email | default: 'hej@langsomtnok.dk' }}">{{ section.settings.email | default: 'hej@langsomtnok.dk' }}</a>
          — vi svarer roligt og hurtigt.
        </p>
        <div class="ln-footer__social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" class="ln-footer__social-link">Instagram</a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener noreferrer" class="ln-footer__social-link">Pinterest</a>
          {%- endif -%}
        </div>
        <div class="ln-footer__legal-info">
          <h3 class="ln-footer__col-label">Juridisk information</h3>
          <p class="ln-footer__legal-desc">{{ section.settings.legal_description | default: 'Langsomt Nok drives af en dansk virksomhed med fokus på ro, håndværk og brugbare produkter til hjemmet.' }}</p>
          <address class="ln-footer__address">
            {{ section.settings.legal_name | default: 'Langsomt Nok ApS' }}<br>
            CVR-nr.: {{ section.settings.cvr | default: '—' }}<br>
            {{ section.settings.address | default: 'Danmark' }}<br>
            E-mail: <a href="mailto:{{ section.settings.email | default: 'hej@langsomtnok.dk' }}">{{ section.settings.email | default: 'hej@langsomtnok.dk' }}</a><br>
            {%- if section.settings.phone != blank -%}
              Telefon: <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
            {%- endif -%}
          </address>
        </div>
      </div>

      {%- comment -%} Shop links {%- endcomment -%}
      <div class="ln-footer__col">
        <h3 class="ln-footer__col-label">Shop</h3>
        <ul class="ln-footer__links">
          <li><a href="/collections/knive">Knive</a></li>
          <li><a href="/collections/slibesten">Slibesten</a></li>
          <li><a href="/collections/magnetiske-holdere">Magnetiske holdere</a></li>
          <li><a href="/pages/keramik">Håndlavet keramik</a></li>
          <li><a href="/collections/pleje-ritualer">Pleje & ritualer</a></li>
        </ul>
      </div>

      {%- comment -%} Guides {%- endcomment -%}
      <div class="ln-footer__col">
        <h3 class="ln-footer__col-label">Guides</h3>
        <ul class="ln-footer__links">
          <li><a href="/blogs/guides">Knivvalg</a></li>
          <li><a href="/blogs/guides">Slibning</a></li>
          <li><a href="/blogs/guides">Pleje</a></li>
          <li><a href="/blogs/guides">Materialer</a></li>
        </ul>
      </div>

      {%- comment -%} Ritualer og gaver {%- endcomment -%}
      <div class="ln-footer__col">
        <h3 class="ln-footer__col-label">Ritualer og gaver</h3>
        <ul class="ln-footer__links">
          <li><a href="/pages/universet">Universet</a></li>
          <li><a href="/collections/gaver">Farsdagsgaver</a></li>
          <li><a href="/pages/universet">Hold din kniv skarp</a></li>
          <li><a href="/pages/universet">Rolig opbevaring</a></li>
          <li><a href="/pages/universet">Find dit køkkenritual</a></li>
        </ul>
      </div>

      {%- comment -%} Brand + Vilkår {%- endcomment -%}
      <div class="ln-footer__col">
        <h3 class="ln-footer__col-label">Brand</h3>
        <ul class="ln-footer__links">
          <li><a href="/pages/om-os">Om Langsomt Nok</a></li>
          <li><a href="/pages/cirklen">Langsomt Cirklen</a></li>
          <li><a href="/pages/kontakt">Kontakt</a></li>
        </ul>
        <h3 class="ln-footer__col-label" style="margin-top: 2rem;">Vilkår</h3>
        <ul class="ln-footer__links ln-footer__links--muted">
          <li><a href="/pages/kontakt">Kontakt</a></li>
          <li><a href="/pages/handelsbetingelser">Handelsbetingelser</a></li>
          <li><a href="/policies/privacy-policy">Privatlivspolitik</a></li>
          <li><a href="/policies/refund-policy">Returnering</a></li>
          <li><a href="/policies/shipping-policy">Levering</a></li>
        </ul>
      </div>

    </div>

    {%- comment -%} Newsletter {%- endcomment -%}
    <div class="ln-footer__newsletter-wrap">
      <div class="ln-footer__newsletter">
        <h3 class="ln-footer__newsletter-title">Langsomt Brev</h3>
        <p class="ln-footer__newsletter-desc">Rolige breve om køkkenritualer, pleje og nye produkter.</p>
        {% form 'customer', id: 'footer-newsletter' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="ln-footer__newsletter-form">
            <input
              type="email"
              name="contact[email]"
              placeholder="Din e-mail"
              required
              autocomplete="email"
              class="ln-footer__newsletter-input"
              aria-label="E-mailadresse"
            >
            <button type="submit" class="ln-footer__newsletter-btn">Tilmeld</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="ln-footer__newsletter-success">Tak! Du er tilmeldt.</p>
          {%- endif -%}
        {% endform %}
        <p class="ln-footer__newsletter-note">Ingen støj. Kun ro.</p>
      </div>
    </div>

    {%- comment -%} Tryg betaling {%- endcomment -%}
    <div class="ln-footer__payment">
      <h3 class="ln-footer__col-label" style="text-align:center; margin-bottom: 0.75rem;">Tryg betaling</h3>
      <p class="ln-footer__payment-desc">Betal sikkert med kort og de betalingsmuligheder, der vises i checkout.</p>
      <div class="ln-footer__payment-badges">
        <span class="ln-footer__payment-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Kort
        </span>
        <span class="ln-footer__payment-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Sikker betaling
        </span>
        <span class="ln-footer__payment-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          Pakket med omhu
        </span>
        <span class="ln-footer__payment-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
          30 dages returret
        </span>
      </div>
    </div>

    {%- comment -%} Copyright {%- endcomment -%}
    <div class="ln-footer__copyright">
      <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Tid. Håndværk. Ro.</p>
    </div>

  </div>
</footer>

<style>
  .ln-footer {
    background: var(--deep);
    color: var(--deep-foreground);
  }
  .ln-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .ln-footer__grid { grid-template-columns: 1fr 1fr; gap: 3rem 4rem; }
  }
  @media (min-width: 1024px) {
    .ln-footer__grid { grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 2rem; }
    .ln-footer__brand { grid-column: 1; }
  }

  .ln-footer__brand-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--deep-foreground);
  }
  .ln-footer__brand-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: color-mix(in oklab, var(--deep-foreground) 65%, transparent);
    max-width: 28rem;
    margin-bottom: 1rem;
  }
  .ln-footer__brand-contact {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 55%, transparent);
    margin-bottom: 0.75rem;
  }
  .ln-footer__brand-contact a {
    color: var(--deep-foreground);
    text-underline-offset: 3px;
  }
  .ln-footer__brand-contact a:hover { text-decoration: underline; }
  .ln-footer__social { display: flex; gap: 1rem; margin-top: 1.5rem; }
  .ln-footer__social-link {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 50%, transparent);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ln-footer__social-link:hover { color: var(--deep-foreground); }

  .ln-footer__legal-info {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in oklab, var(--deep-foreground) 10%, transparent);
    max-width: 28rem;
  }
  .ln-footer__legal-desc {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 60%, transparent);
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .ln-footer__address {
    font-style: normal;
    font-size: 0.75rem;
    color: color-mix(in oklab, var(--deep-foreground) 45%, transparent);
    line-height: 1.8;
  }
  .ln-footer__address a { transition: color 0.2s ease; }
  .ln-footer__address a:hover { color: var(--deep-foreground); }

  .ln-footer__col-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--deep-foreground) 40%, transparent);
    margin-bottom: 1rem;
  }
  .ln-footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ln-footer__links a {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 60%, transparent);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ln-footer__links a:hover { color: var(--deep-foreground); }
  .ln-footer__links--muted a { color: color-mix(in oklab, var(--deep-foreground) 40%, transparent); }
  .ln-footer__links--muted a:hover { color: color-mix(in oklab, var(--deep-foreground) 60%, transparent); }

  /* Newsletter */
  .ln-footer__newsletter-wrap {
    border-top: 1px solid color-mix(in oklab, var(--deep-foreground) 10%, transparent);
    margin-top: 4rem;
    padding-top: 2.5rem;
  }
  .ln-footer__newsletter {
    max-width: 28rem;
    margin: 0 auto;
    text-align: center;
  }
  .ln-footer__newsletter-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    color: var(--deep-foreground);
  }
  .ln-footer__newsletter-desc {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 50%, transparent);
    margin-bottom: 1rem;
  }
  .ln-footer__newsletter-form { display: flex; gap: 0.5rem; }
  .ln-footer__newsletter-input {
    flex: 1;
    height: 2.5rem;
    padding: 0 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid color-mix(in oklab, var(--deep-foreground) 10%, transparent);
    background: color-mix(in oklab, var(--deep-foreground) 5%, transparent);
    color: var(--deep-foreground);
    font-size: 0.875rem;
    outline: none;
  }
  .ln-footer__newsletter-input::placeholder { color: color-mix(in oklab, var(--deep-foreground) 30%, transparent); }
  .ln-footer__newsletter-input:focus { border-color: color-mix(in oklab, var(--cta) 50%, transparent); }
  .ln-footer__newsletter-btn {
    height: 2.5rem;
    padding: 0 1.25rem;
    border-radius: 0.375rem;
    background: var(--cta);
    color: var(--cta-foreground);
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }
  .ln-footer__newsletter-btn:hover { opacity: 0.9; }
  .ln-footer__newsletter-success {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 65%, transparent);
  }
  .ln-footer__newsletter-note {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: color-mix(in oklab, var(--deep-foreground) 25%, transparent);
  }

  /* Payment */
  .ln-footer__payment {
    border-top: 1px solid color-mix(in oklab, var(--deep-foreground) 10%, transparent);
    padding-top: 2rem;
    margin-top: 0;
    padding-bottom: 2rem;
  }
  .ln-footer__payment-desc {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 60%, transparent);
    text-align: center;
    max-width: 28rem;
    margin: 0 auto 1.25rem;
    line-height: 1.65;
  }
  .ln-footer__payment-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }
  .ln-footer__payment-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: color-mix(in oklab, var(--deep-foreground) 50%, transparent);
  }
  .ln-footer__payment-badge svg { color: var(--cta); opacity: 1; }

  /* Copyright */
  .ln-footer__copyright {
    border-top: 1px solid color-mix(in oklab, var(--deep-foreground) 10%, transparent);
    padding-top: 2rem;
    text-align: center;
  }
  .ln-footer__copyright p {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--deep-foreground) 30%, transparent);
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "email", "label": "E-mail", "default": "hej@langsomtnok.dk" },
    { "type": "text", "id": "phone", "label": "Telefon", "default": "+45 27 12 84 97" },
    { "type": "textarea", "id": "brand_description", "label": "Brand-beskrivelse", "default": "Køkkenredskaber og keramik skabt til dem, der ikke skynder sig gennem det vigtige. Træ, stål, olie, tid." },
    { "type": "text", "id": "legal_name", "label": "Juridisk navn", "default": "Langsomt Nok ApS" },
    { "type": "text", "id": "cvr", "label": "CVR-nr." },
    { "type": "text", "id": "address", "label": "Adresse" },
    { "type": "textarea", "id": "legal_description", "label": "Juridisk beskrivelse" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest URL" }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
