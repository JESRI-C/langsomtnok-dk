<section class="section-padding" style="background: color-mix(in oklab, var(--linen) 60%, transparent);">
  <div class="container-calm">
    <div class="ln-manifest__grid">
      <div class="ln-manifest__image-col">
        <div style="overflow: hidden; border-radius: 0.5rem; aspect-ratio: 4/5;">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 900 | image_tag:
              loading: 'lazy',
              alt: section.settings.image_alt | default: 'Langsomt Nok',
              style: 'width:100%;height:100%;object-fit:cover;'
            }}
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(145deg, color-mix(in oklab,var(--soft) 80%,var(--walnut)) 0%, var(--soft) 60%, color-mix(in oklab,var(--linen) 70%,var(--copper)) 100%);"></div>
          {%- endif -%}
        </div>
      </div>

      <div class="ln-manifest__text-col">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 style="font-size: clamp(2rem, 6vw, 4rem); margin-top: 0.75rem; margin-bottom: 2rem; line-height: 1.05;">{{ section.settings.heading }}</h2>
        <div style="display: flex; flex-direction: column; gap: 1.25rem; max-width: 36rem;">
          {%- for block in section.blocks -%}
            <p style="font-size: clamp(1rem, 2vw, 1.125rem); color: var(--foreground); opacity: 0.75; line-height: 1.75;">{{ block.settings.text }}</p>
          {%- endfor -%}
        </div>
        {%- if section.settings.cta_label != blank -%}
          <div style="margin-top: 2.5rem;">
            <a href="{{ section.settings.cta_url | default: '/pages/om-os' }}"
               style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 500; color: var(--walnut); border-bottom: 1px solid color-mix(in oklab, var(--walnut) 30%, transparent); padding-bottom: 0.25rem; transition: gap 200ms;">
              {{ section.settings.cta_label }}
              <svg style="width:1rem;height:1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .ln-manifest__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .ln-manifest__image-col { order: 2; }
  .ln-manifest__text-col { order: 1; }
  @media (min-width: 1024px) {
    .ln-manifest__grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
    .ln-manifest__image-col { order: 1; }
    .ln-manifest__text-col { order: 2; padding-left: 1.5rem; }
  }
</style>

{% schema %}
{
  "name": "Brand manifest",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Billede" },
    { "type": "text", "id": "image_alt", "label": "Billedtekst" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Manifest" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Ikke skabt til fart." },
    { "type": "text", "id": "cta_label", "label": "Link-tekst", "default": "Læs vores historie" },
    { "type": "url", "id": "cta_url", "label": "Link-URL" }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Afsnit",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Tekst" }
      ]
    }
  ],
  "presets": [{
    "name": "Brand manifest",
    "blocks": [
      { "type": "paragraph", "settings": { "text": "Langsomt Nok er køkkenredskaber med vægt, ro og materialer, der gerne må mærkes." } },
      { "type": "paragraph", "settings": { "text": "Til madlavning, der begynder før gryden koger." } },
      { "type": "paragraph", "settings": { "text": "Til hænder, der vælger med omhu." } }
    ]
  }]
}
{% endschema %}
