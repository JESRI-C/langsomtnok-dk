{%- comment -%} BLOG / GUIDES-HUB — 1:1 port af src/routes/guides.index.tsx {%- endcomment -%}
<div class="ln-blog section-padding" style="padding-top: 3rem;">
  <div class="container-calm">
    <header class="ln-blog__hero">
      <span class="eyebrow">{{ blog.title }}</span>
      <h1 class="ln-blog__title">Rolige guides til køkkenet</h1>
      <p>Ingen larm, ingen gætværk. Kun rolige svar på det, der gør en forskel i køkkenet.</p>
    </header>

    {%- if blog.all_tags.size > 0 -%}
      <div class="ln-blog__filters">
        <a href="{{ blog.url }}" class="ln-blog__filter{% unless current_tags %} is-active{% endunless %}">Alle</a>
        {%- for tag in blog.all_tags -%}
          <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="ln-blog__filter{% if current_tags contains tag %} is-active{% endif %}">{{ tag }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- paginate blog.articles by 12 -%}
      <div class="ln-blog__grid">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="ln-guide-card lift-on-hover">
            <div class="ln-guide-card__image-wrap">
              {%- if article.image -%}
                <div class="ln-guide-card__image-inner">
                  {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.image.alt | default: article.title, class: 'ln-guide-card__img' }}
                </div>
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--soft);"></div>
              {%- endif -%}
            </div>
            <div class="ln-guide-card__body">
              {%- if article.tags.size > 0 -%}<span class="ln-guide-card__tag">{{ article.tags.first }}</span>{%- endif -%}
              <h3 class="ln-guide-card__title">{{ article.title }}</h3>
              <p class="ln-guide-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 110 }}</p>
              <span class="arrow-link" style="color: var(--cta);">Læs guiden
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <nav class="ln-blog__pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="btn-outline-calm">← Forrige</a>{%- endif -%}
          <span>Side {{ paginate.current_page }} af {{ paginate.pages }}</span>
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="btn-outline-calm">Næste →</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

<style>
  .ln-blog__hero { max-width: 42rem; margin-bottom: 2.5rem; }
  .ln-blog__title { font-size: clamp(2rem, 6vw, 3.5rem); margin: 0.5rem 0 1rem; }
  .ln-blog__hero p { color: var(--muted-foreground); line-height: 1.75; }
  .ln-blog__filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .ln-blog__filter { font-size: 0.8125rem; padding: 0.375rem 0.875rem; border-radius: 999px; border: 1px solid var(--border); color: var(--muted-foreground); }
  .ln-blog__filter:hover { border-color: var(--walnut); color: var(--walnut); }
  .ln-blog__filter.is-active { background: var(--walnut); border-color: var(--walnut); color: var(--cta-foreground); }
  .ln-blog__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; }
  .ln-guide-card { display: block; border-radius: 0.75rem; overflow: hidden; border: 1px solid color-mix(in oklab, var(--border) 60%, transparent); background: var(--card); }
  .ln-guide-card__image-wrap { aspect-ratio: 3/2; overflow: hidden; background: var(--soft); }
  .ln-guide-card__image-inner { width: 100%; height: 100%; transition: transform 600ms ease-out; }
  .ln-guide-card:hover .ln-guide-card__image-inner { transform: scale(1.04); }
  .ln-guide-card__img { width: 100%; height: 100%; object-fit: cover; }
  .ln-guide-card__body { padding: 1.25rem 1.375rem 1.5rem; }
  .ln-guide-card__tag { display: block; font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--copper); margin-bottom: 0.5rem; }
  .ln-guide-card__title { font-size: 1.1875rem; line-height: 1.3; margin-bottom: 0.5rem; transition: color 0.2s; }
  .ln-guide-card:hover .ln-guide-card__title { color: var(--walnut); }
  .ln-guide-card__excerpt { font-size: 0.875rem; color: var(--muted-foreground); line-height: 1.6; margin-bottom: 0.75rem; }
  .ln-blog__pagination { display: flex; align-items: center; justify-content: center; gap: 1.5rem; margin-top: 3.5rem; font-size: 0.875rem; color: var(--muted-foreground); }
</style>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
