<section class="section-padding" style="background: color-mix(in oklab, var(--soft) 50%, transparent);">
  <div class="container-calm" style="max-width: 80rem;">
    <div style="text-align: center; max-width: 40rem; margin: 0 auto 3rem;">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); margin-top: 0.5rem; margin-bottom: 1rem;">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p style="color: var(--muted-foreground); line-height: 1.65;">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem 1.5rem;">
      {%- for block in section.blocks -%}
        <div style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem; border-radius: 0.5rem; background: color-mix(in oklab, var(--background) 60%, transparent); border: 1px solid color-mix(in oklab, var(--border) 40%, transparent);">
          <span style="flex-shrink: 0; color: var(--cta); margin-top: 0.125rem;">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg class="icon" style="width:1.25rem;height:1.25rem;" viewBox="0 0 24 24"><path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>
              {%- when 'shield' -%}
                <svg class="icon" style="width:1.25rem;height:1.25rem;" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              {%- when 'rotate' -%}
                <svg class="icon" style="width:1.25rem;height:1.25rem;" viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              {%- when 'message' -%}
                <svg class="icon" style="width:1.25rem;height:1.25rem;" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {%- endcase -%}
          </span>
          <div>
            <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.125rem; margin-bottom: 0.375rem;">{{ block.settings.title }}</h3>
            <p style="font-size: 0.875rem; color: var(--muted-foreground); line-height: 1.6;">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Tryghedsbar",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tryghed" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Handel med ro i maven" },
    { "type": "textarea", "id": "subheading", "label": "Underoverskrift", "default": "Vi er et nyt dansk køkkenunivers. Derfor bygger vi tillid på det enkle: tryg betaling, tydelige vilkår, ærlige produktbilleder og omhyggelig pakning." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Tryghedspunkt",
      "settings": [
        { "type": "select", "id": "icon", "label": "Ikon", "options": [
          { "value": "truck", "label": "Levering" },
          { "value": "shield", "label": "Skjold" },
          { "value": "rotate", "label": "Retur" },
          { "value": "message", "label": "Besked" }
        ], "default": "shield" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "textarea", "id": "text", "label": "Tekst" }
      ]
    }
  ],
  "presets": [{
    "name": "Tryghedsbar",
    "blocks": [
      { "type": "item", "settings": { "icon": "truck", "title": "Sendes fra Danmark", "text": "Din ordre pakkes med omhu og sendes fra Danmark." } },
      { "type": "item", "settings": { "icon": "shield", "title": "Tryg betaling", "text": "Betaling foregår sikkert via webshoppen." } },
      { "type": "item", "settings": { "icon": "rotate", "title": "30 dages returret", "text": "Du har tid til at mærke efter." } },
      { "type": "item", "settings": { "icon": "message", "title": "Direkte kontakt", "text": "Skriv til os, hvis du er i tvivl om et produkt." } }
    ]
  }]
}
{% endschema %}
