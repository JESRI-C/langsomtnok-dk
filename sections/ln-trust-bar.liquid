<section class="ln-trust-section">
  <div class="container-calm">
    <div class="ln-trust-section__strip">
      {%- for block in section.blocks -%}
        <div class="ln-trust-section__item" {{ block.shopify_attributes }}>
          <span class="ln-trust-section__icon">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'shield' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              {%- when 'rotate' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
              {%- when 'message' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {%- when 'package' -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            {%- endcase -%}
          </span>
          <div class="ln-trust-section__text">
            <strong class="ln-trust-section__title">{{ block.settings.title }}</strong>
            {%- if block.settings.text != blank -%}
              <span class="ln-trust-section__desc">{{ block.settings.text }}</span>
            {%- endif -%}
          </div>
        </div>
        {%- unless forloop.last -%}
          <span class="ln-trust-section__divider" aria-hidden="true"></span>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .ln-trust-section {
    padding: 2.5rem 0;
    background: color-mix(in oklab, var(--soft) 50%, var(--background));
    border-top: 1px solid color-mix(in oklab, var(--foreground) 6%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 6%, transparent);
  }
  .ln-trust-section__strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem 2rem;
  }
  @media (min-width: 768px) {
    .ln-trust-section__strip {
      flex-wrap: nowrap;
      gap: 0;
      justify-content: space-between;
    }
  }
  .ln-trust-section__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 160px;
    max-width: 260px;
  }
  .ln-trust-section__icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: color-mix(in oklab, var(--cta) 10%, var(--background));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cta);
  }
  .ln-trust-section__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .ln-trust-section__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--foreground);
  }
  .ln-trust-section__desc {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    line-height: 1.4;
  }
  .ln-trust-section__divider {
    display: none;
  }
  @media (min-width: 768px) {
    .ln-trust-section__divider {
      display: block;
      width: 1px;
      height: 2.5rem;
      background: color-mix(in oklab, var(--foreground) 10%, transparent);
      flex-shrink: 0;
      margin: 0 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Tryghedsbar",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Tryghedspunkt",
      "settings": [
        { "type": "select", "id": "icon", "label": "Ikon", "options": [
          { "value": "truck", "label": "Levering" },
          { "value": "package", "label": "Pakke" },
          { "value": "shield", "label": "Skjold" },
          { "value": "rotate", "label": "Retur" },
          { "value": "message", "label": "Besked" }
        ], "default": "shield" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "text", "id": "text", "label": "Undertekst" }
      ]
    }
  ],
  "presets": [{
    "name": "Tryghedsbar",
    "blocks": [
      { "type": "item", "settings": { "icon": "truck", "title": "Sendes fra Danmark", "text": "Levering 1–2 hverdage" } },
      { "type": "item", "settings": { "icon": "package", "title": "Fri fragt over 599 kr", "text": "Pakket med omhu" } },
      { "type": "item", "settings": { "icon": "rotate", "title": "30 dages returret", "text": "Du har tid til at mærke efter" } },
      { "type": "item", "settings": { "icon": "shield", "title": "Sikker betaling", "text": "Betaling foregår sikkert" } }
    ]
  }]
}
{% endschema %}
