<div class="ln-tbar">
  <div class="container-calm">
    <div class="ln-tbar__row">

      <div class="ln-tbar__item">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <div>
          <strong>{{ section.settings.item1_title | default: 'Sendes fra Danmark' }}</strong>
          <span>{{ section.settings.item1_text | default: 'Levering 1–2 hverdage' }}</span>
        </div>
      </div>

      <span class="ln-tbar__sep" aria-hidden="true"></span>

      <div class="ln-tbar__item">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        <div>
          <strong>{{ section.settings.item2_title | default: 'Fri fragt over 599 kr' }}</strong>
          <span>{{ section.settings.item2_text | default: 'Pakket med omhu' }}</span>
        </div>
      </div>

      <span class="ln-tbar__sep" aria-hidden="true"></span>

      <div class="ln-tbar__item">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
        <div>
          <strong>{{ section.settings.item3_title | default: '30 dages returret' }}</strong>
          <span>{{ section.settings.item3_text | default: 'Du har tid til at mærke efter' }}</span>
        </div>
      </div>

      <span class="ln-tbar__sep" aria-hidden="true"></span>

      <div class="ln-tbar__item">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <div>
          <strong>{{ section.settings.item4_title | default: 'Sikker betaling' }}</strong>
          <span>{{ section.settings.item4_text | default: 'Betaling foregår sikkert' }}</span>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .ln-tbar {
    background: color-mix(in oklab, var(--soft) 55%, var(--background));
    border-top: 1px solid color-mix(in oklab, var(--foreground) 7%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 7%, transparent);
    padding: 2rem 0;
  }
  .ln-tbar__row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .ln-tbar__row::-webkit-scrollbar { display: none; }

  .ln-tbar__item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.625rem;
    flex: 1 0 auto;
    white-space: nowrap;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }
  .ln-tbar__item svg {
    flex-shrink: 0;
    color: var(--cta);
    opacity: 0.85;
  }
  .ln-tbar__item div {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .ln-tbar__item strong {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--foreground);
    line-height: 1.2;
  }
  .ln-tbar__item span {
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    line-height: 1.2;
  }
  .ln-tbar__sep {
    width: 1px;
    height: 2rem;
    background: color-mix(in oklab, var(--foreground) 10%, transparent);
    flex-shrink: 0;
  }
</style>

{% schema %}
{
  "name": "Tryghedsbar",
  "settings": [
    { "type": "text", "id": "item1_title", "label": "Punkt 1 — titel", "default": "Sendes fra Danmark" },
    { "type": "text", "id": "item1_text", "label": "Punkt 1 — undertekst", "default": "Levering 1–2 hverdage" },
    { "type": "text", "id": "item2_title", "label": "Punkt 2 — titel", "default": "Fri fragt over 599 kr" },
    { "type": "text", "id": "item2_text", "label": "Punkt 2 — undertekst", "default": "Pakket med omhu" },
    { "type": "text", "id": "item3_title", "label": "Punkt 3 — titel", "default": "30 dages returret" },
    { "type": "text", "id": "item3_text", "label": "Punkt 3 — undertekst", "default": "Du har tid til at mærke efter" },
    { "type": "text", "id": "item4_title", "label": "Punkt 4 — titel", "default": "Sikker betaling" },
    { "type": "text", "id": "item4_text", "label": "Punkt 4 — undertekst", "default": "Betaling foregår sikkert" }
  ],
  "presets": [{ "name": "Tryghedsbar" }]
}
{% endschema %}
