<section class="section-padding">
  <div class="container-calm">
    <div style="text-align: center; max-width: 40rem; margin: 0 auto 3.5rem;">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 style="font-size: clamp(1.75rem, 5vw, 3.25rem); margin-top: 0.5rem; margin-bottom: 1rem;">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p style="color: var(--muted-foreground);">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="ln-rituals__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url }}" class="ln-ritual-card" {{ block.shopify_attributes }}>
          <span style="display: block; font-family: 'Playfair Display', Georgia, serif; color: var(--copper); opacity: 0.7; font-size: 0.875rem; margin-bottom: 1.5rem;">
            0{{ forloop.index }}
          </span>
          <h3 class="ln-ritual-card__title">{{ block.settings.title }}</h3>
          <p style="font-size: 0.875rem; color: var(--muted-foreground); margin-bottom: 1.5rem; line-height: 1.6;">{{ block.settings.text }}</p>
          <span class="arrow-link" style="color: var(--cta); font-size: 0.875rem; font-weight: 500;">
            {{ block.settings.cta_label | default: 'Se mere' }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.quiz_label != blank -%}
      <div style="margin-top: 2.5rem; text-align: center;">
        <a href="{{ section.settings.quiz_url | default: '/find-dit-ritual' }}"
           style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 500; color: var(--walnut); border-bottom: 1px solid color-mix(in oklab, var(--walnut) 30%, transparent); padding-bottom: 0.25rem; transition: gap 200ms;">
          {{ section.settings.quiz_label }}
          <svg style="width:0.875rem;height:0.875rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .ln-rituals__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem 1.5rem;
  }
  .ln-ritual-card {
    display: block;
    padding: 2rem 2.5rem;
    border-radius: 0.5rem;
    background: color-mix(in oklab, var(--soft) 60%, transparent);
    border: 1px solid color-mix(in oklab, var(--border) 40%, transparent);
    transition: background 500ms;
  }
  .ln-ritual-card:hover { background: var(--soft); }
  .ln-ritual-card__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    line-height: 1.3;
    margin-bottom: 0.75rem;
    transition: color 200ms;
  }
  .ln-ritual-card:hover .ln-ritual-card__title { color: var(--walnut); }
</style>

{% schema %}
{
  "name": "Ritualvalg",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Vejledning" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Find dit første ritual" },
    { "type": "text", "id": "subheading", "label": "Underoverskrift", "default": "Tre stille indgange. Vælg den, der passer til dig — vi guider dig roligt videre." },
    { "type": "text", "id": "quiz_label", "label": "Quiz-link tekst", "default": "Find dit køkkenritual" },
    { "type": "url", "id": "quiz_url", "label": "Quiz-link URL" }
  ],
  "blocks": [
    {
      "type": "choice",
      "name": "Ritualvalg",
      "settings": [
        { "type": "url", "id": "url", "label": "URL" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "text", "id": "text", "label": "Beskrivelse" },
        { "type": "text", "id": "cta_label", "label": "CTA-tekst", "default": "Se mere" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{
    "name": "Ritualvalg",
    "blocks": [
      { "type": "choice", "settings": { "title": "Jeg vil have min første rigtige kniv", "text": "Til dig, der vil starte med ét godt redskab.", "cta_label": "Se knivene" } },
      { "type": "choice", "settings": { "title": "Jeg vil passe bedre på mine redskaber", "text": "Slibning, olie og pleje til hverdagen.", "cta_label": "Se plejen" } },
      { "type": "choice", "settings": { "title": "Jeg vil give en gave med mening", "text": "Noget der bliver brugt — og husket.", "cta_label": "Se gaverne" } }
    ]
  }]
}
{% endschema %}
