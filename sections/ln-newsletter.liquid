<section class="section-padding {% if section.settings.variant == 'dark' %}ln-newsletter--dark{% endif %}">
  <div class="container-calm" style="max-width: 40rem; text-align: center;">
    <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 1rem;">{{ section.settings.heading }}</h2>
    <p class="ln-newsletter__sub">{{ section.settings.subheading }}</p>

    {%- form 'customer', id: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="ln-newsletter__success">Tak — du er tilmeldt {{ section.settings.heading | downcase }}.</p>
      {%- else -%}
        {%- if form.errors -%}
          <p style="font-size: 0.8125rem; color: #c0392b; margin-bottom: 1rem;">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="ln-newsletter__form">
          <input
            type="text"
            name="contact[first_name]"
            placeholder="Fornavn (valgfrit)"
            class="ln-newsletter__input ln-newsletter__input--name"
            autocomplete="given-name"
          >
          <input
            type="email"
            name="contact[email]"
            placeholder="Din e-mail"
            required
            class="ln-newsletter__input ln-newsletter__input--email"
            autocomplete="email"
          >
          <button type="submit" class="btn-cta">{{ section.settings.button_label }}</button>
        </div>
      {%- endif -%}
    {%- endform -%}

    <p class="ln-newsletter__footnote">{{ section.settings.footnote }}</p>
  </div>
</section>

<style>
  .ln-newsletter--dark {
    background: var(--deep);
    color: var(--deep-foreground);
  }
  .ln-newsletter__sub {
    font-size: 1rem;
    line-height: 1.7;
    max-width: 32rem;
    margin: 0 auto 2rem;
    opacity: 0.75;
  }
  .ln-newsletter__form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    max-width: 32rem;
    margin: 0 auto;
  }
  .ln-newsletter__input {
    height: 3rem;
    padding: 0 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    font-size: 0.875rem;
    font-family: inherit;
    outline: none;
    transition: border-color 200ms;
  }
  .ln-newsletter--dark .ln-newsletter__input {
    background: color-mix(in oklab, var(--deep-foreground) 5%, transparent);
    border-color: color-mix(in oklab, var(--deep-foreground) 10%, transparent);
    color: var(--deep-foreground);
  }
  .ln-newsletter__input:focus { border-color: color-mix(in oklab, var(--cta) 60%, transparent); }
  .ln-newsletter__input--name { width: 9rem; flex-shrink: 0; }
  .ln-newsletter__input--email { flex: 1; min-width: 180px; }
  .ln-newsletter__success {
    font-size: 0.9375rem; font-weight: 500;
    padding: 1rem; border-radius: 0.5rem;
    background: color-mix(in oklab, var(--cta) 10%, transparent);
    color: var(--cta);
  }
  .ln-newsletter__footnote {
    font-size: 0.75rem; opacity: 0.4; margin-top: 1rem;
  }
</style>

{% schema %}
{
  "name": "Nyhedsbrev",
  "settings": [
    { "type": "select", "id": "variant", "label": "Baggrund", "options": [
      { "value": "light", "label": "Lys" },
      { "value": "dark", "label": "Mørk" }
    ], "default": "light" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Langsomt Brev" },
    { "type": "textarea", "id": "subheading", "label": "Underoverskrift", "default": "Et øjeblik af ro i din indbakke. Guides, ritualer og fortællinger om træ, stål og tid." },
    { "type": "text", "id": "button_label", "label": "Knaptekst", "default": "Modtag Langsomt Brev" },
    { "type": "text", "id": "footnote", "label": "Bundtekst", "default": "Rolige breve. Ingen støj." }
  ],
  "presets": [{ "name": "Nyhedsbrev" }]
}
{% endschema %}
