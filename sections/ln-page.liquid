{%- comment -%} STATISK SIDE — matcher LegalPageLayout fra Lovable {%- endcomment -%}
<div class="ln-page section-padding" style="padding-top: 4rem;">
  <article class="ln-page__container">
    <h1 class="ln-page__title">{{ page.title }}</h1>
    <div class="ln-page__body rte">{{ page.content }}</div>
  </article>
</div>

<style>
  .ln-page__container { max-width: 56.25rem; margin-inline: auto; padding-inline: clamp(1.5rem, 5vw, 4rem); }
  .ln-page__title { font-size: clamp(2rem, 6vw, 3rem); margin-bottom: 1.5rem; }
  .ln-page__body { color: var(--muted-foreground); line-height: 1.75; }
</style>

{% schema %}
{ "name": "Statisk side", "settings": [] }
{% endschema %}
