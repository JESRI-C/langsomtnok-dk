{%- comment -%}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- assign first_variant = product.selected_or_first_available_variant -%}
{%- assign product_image = product.featured_image -%}

<a href="{{ product.url }}" class="ln-product-card lift-on-hover">
  <div class="ln-product-card__image-wrap">
    {%- if product_image -%}
      <div class="ln-product-card__image-inner">
        {{ product_image | image_url: width: 600 | image_tag:
          loading: 'lazy',
          alt: product_image.alt | default: product.title,
          class: 'ln-product-card__img',
          widths: '300, 400, 600',
          sizes: '(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 25vw'
        }}
      </div>
    {%- else -%}
      <div style="width:100%;height:100%;background:var(--soft);"></div>
    {%- endif -%}

    {%- unless product.available -%}
      <span class="ln-product-card__badge">Udsolgt</span>
    {%- endunless -%}
  </div>

  <div class="ln-product-card__body">
    {%- if product.product_type != blank -%}
      <span class="ln-product-card__type">{{ product.product_type }}</span>
    {%- endif -%}
    <h3 class="ln-product-card__title">{{ product.title }}</h3>
    <div class="ln-product-card__price">
      {%- if first_variant.compare_at_price > first_variant.price -%}
        <span class="ln-product-card__price--sale">{{ first_variant.price | money }}</span>
        <s class="ln-product-card__price--compare">{{ first_variant.compare_at_price | money }}</s>
      {%- else -%}
        <span>{{ first_variant.price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</a>

<style>
  .ln-product-card {
    display: block;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
    background: var(--card);
    overflow: hidden;
  }
  .ln-product-card__image-wrap {
    position: relative;
    overflow: hidden;
    background: var(--soft);
    aspect-ratio: 4/5;
  }
  .ln-product-card__image-inner {
    width: 100%; height: 100%;
    transition: transform 600ms ease-out;
  }
  .ln-product-card:hover .ln-product-card__image-inner { transform: scale(1.04); }
  .ln-product-card__img { width: 100%; height: 100%; object-fit: cover; }
  .ln-product-card__badge {
    position: absolute; top: 0.75rem; left: 0.75rem;
    background: var(--foreground); color: var(--background);
    font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
    padding: 0.25rem 0.625rem; border-radius: 0.25rem;
  }
  .ln-product-card__body { padding: 1rem 1.125rem 1.25rem; }
  .ln-product-card__type {
    display: block; font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--copper); margin-bottom: 0.375rem;
  }
  .ln-product-card__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.0625rem; line-height: 1.3; margin-bottom: 0.5rem;
    transition: color 200ms;
  }
  .ln-product-card:hover .ln-product-card__title { color: var(--walnut); }
  .ln-product-card__price { font-size: 0.9375rem; font-weight: 500; }
  .ln-product-card__price--sale { color: var(--cta); }
  .ln-product-card__price--compare { color: var(--muted-foreground); font-size: 0.8125rem; margin-left: 0.375rem; }
</style>
