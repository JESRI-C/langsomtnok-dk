{%- comment -%}
  Rolig service-/trust-bar. Genbruges på produkt-, kollektions- og kurvsider.
  Matcher TrustBar-komponenten fra Lovable.
{%- endcomment -%}
<div class="ln-trustbar">
  <div class="ln-trustbar__item">
    <svg class="icon" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    <div><strong>Sendes fra Danmark</strong><span>1-2 hverdage</span></div>
  </div>
  <div class="ln-trustbar__item">
    <svg class="icon" viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
    <div><strong>Fri fragt over 599 kr</strong><span>i hele Danmark</span></div>
  </div>
  <div class="ln-trustbar__item">
    <svg class="icon" viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
    <div><strong>30 dages returret</strong><span>handel i ro</span></div>
  </div>
  <div class="ln-trustbar__item">
    <svg class="icon" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <div><strong>Sikker betaling</strong><span>krypteret checkout</span></div>
  </div>
</div>

<style>
  .ln-trustbar {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 1.5rem;
    padding: 1.5rem;
    border: 1px solid color-mix(in oklab, var(--border) 70%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in oklab, var(--soft) 35%, transparent);
  }
  @media (min-width: 768px) { .ln-trustbar { grid-template-columns: repeat(4, 1fr); } }
  .ln-trustbar__item { display: flex; align-items: center; gap: 0.75rem; }
  .ln-trustbar__item .icon { width: 1.5rem; height: 1.5rem; color: var(--cta); flex-shrink: 0; }
  .ln-trustbar__item div { display: flex; flex-direction: column; line-height: 1.3; }
  .ln-trustbar__item strong { font-size: 0.8125rem; font-weight: 600; color: var(--foreground); }
  .ln-trustbar__item span { font-size: 0.75rem; color: var(--muted-foreground); }
</style>
