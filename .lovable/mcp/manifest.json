{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "langsomt-nok-mcp",
      "version": "0.1.0",
      "title": "Langsomt Nok"
    },
    "tools": [
      {
        "name": "search_products",
        "title": "Search products",
        "description": "Search the Langsomt Nok Shopify catalog by keyword. Returns product title, handle, price, availability, and product URL.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Danish or English keyword, e.g. 'knivsliber' or 'keramik'."
            },
            "limit": {
              "default": 8,
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "get_product",
        "title": "Get product by handle",
        "description": "Fetch full details for a single Langsomt Nok product by its Shopify handle: title, description, price, variants, availability, and product URL.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "handle": {
              "type": "string",
              "minLength": 1,
              "description": "Shopify product handle, e.g. 'praecisionssliberen-valnoed'."
            }
          },
          "required": [
            "handle"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_articles",
        "title": "List guides & articles",
        "description": "List Langsomt Nok's Danish guides and articles (kniv, keramik, ritualer). Optionally filter by category or keyword.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Optional category. One of: Knivvalg, Slibning, Pleje, Materialer, Gaver, Langsom mad.",
              "type": "string"
            },
            "query": {
              "description": "Optional keyword filter on title/excerpt.",
              "type": "string"
            },
            "limit": {
              "default": 20,
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
